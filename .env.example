# LLM: set the API key for llm.provider in config/competitors.yaml
# qwen    -> DASHSCOPE_API_KEY
# openai  -> OPENAI_API_KEY
# deepseek -> DEEPSEEK_API_KEY
# moonshot -> MOONSHOT_API_KEY
# zhipu   -> ZHIPU_API_KEY
# azure/custom -> AZURE_OPENAI_API_KEY or LLM_API_KEY

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
AZURE_OPENAI_API_KEY=

# Optional: override preset base URL (required for custom/azure providers)
LLM_BASE_URL=

# Optional: fallback API key when provider-specific key is empty
LLM_API_KEY=

# Search (optional)
SEARCH_API_KEY=
